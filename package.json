{
  "name": "bike-rn",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@tanstack/react-query": "^5.100.14",
    "expo": "~56.0.15",
    "expo-asset": "~56.0.19",
    "expo-auth-session": "~56.0.15",
    "expo-constants": "~56.0.20",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "~56.0.22",
    "expo-linking": "~56.0.15",
    "expo-location": "~56.0.20",
    "expo-router": "~56.2.14",
    "expo-secure-store": "~56.0.4",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-task-manager": "~56.0.21",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-maps": "1.27.2",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.14",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.5",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "start:lan": "expo start --lan --port 8081",
    "proxy:expo-go": "node ops/prototype/expo-go-dev-proxy.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --runInBand",
    "typecheck": "tsc --noEmit",
    "check:prototype": "node ops/smoke/prototype_readiness_check.mjs",
    "check:native": "node ops/smoke/native_readiness_check.mjs",
    "c003:ngrok-preflight": "bash ops/smoke/c003_ngrok_preflight.sh"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/src/**/*.test.ts",
      "**/src/**/*.test.tsx"
    ]
  },
  "expo": {
    "autolinking": {
      "searchPaths": [
        "./node_modules"
      ]
    }
  },
  "private": true
