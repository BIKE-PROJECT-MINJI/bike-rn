{
  "name": "bike-rn",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@tanstack/react-query": "^5.100.14",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.13",
    "expo-auth-session": "~7.0.11",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "0.81.5",
    "react-native-maps": "1.20.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "start": "expo start",
    "start:lan": "expo start --lan --port 8081",
    "proxy:expo-go": "node ops/prototype/expo-go-dev-proxy.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest --runInBand",
    "typecheck": "tsc --noEmit",
    "check:prototype": "node ops/smoke/prototype_readiness_check.mjs",
    "check:native": "node ops/smoke/native_readiness_check.mjs",
    "c003:ngrok-preflight": "bash ops/smoke/c003_ngrok_preflight.sh"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/src/**/*.test.ts",
      "**/src/**/*.test.tsx"
    ]
  },
  "expo": {
    "autolinking": {
      "searchPaths": [
        "./node_modules"
      ]
    }
  },
  "private": true
}
